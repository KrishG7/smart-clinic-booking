# ============================================
# Smart Clinic Booking — Backend Configuration
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=smart_clinic_booking

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# OTP Configuration
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6

# GPS Geofencing (Clinic Location)
CLINIC_LATITUDE=28.6139
CLINIC_LONGITUDE=77.2090
GEOFENCE_RADIUS_METERS=200

# Sync Configuration
SYNC_BATCH_SIZE=50
SYNC_RETRY_ATTEMPTS=3
